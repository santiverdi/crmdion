# === Hotel Dion - Configuración ===

# Brevo (email marketing) - Obtener en https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Google Reviews link del Hotel Dion
GOOGLE_REVIEWS_LINK=https://g.page/r/HOTEL_DION_REVIEW

# Web de reservas directas
HOTEL_WEB_URL=https://hoteldion.com

# --- Fase 3: Landing page cualificador ---

# Webhook para notificar al conserje (Make.com o n8n)
WEBHOOK_NOTIFY_URL=

# Teléfono del conserje (formato 549XXXXXXXXXX)
CONSERJE_TELEFONO=

# Puerto del servidor
PORT=8000

# Secret key para firmar sesiones
SECRET_KEY=cambiar-esto-por-algo-seguro
